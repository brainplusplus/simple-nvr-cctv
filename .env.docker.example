# ===== Application Settings =====
APP_NAME=SaaS Boilerplate
GO2RTC_URL=http://go2rtc:1984

# ===== Database Settings =====
DB_DRIVER=postgres
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SCHEMA=boilerplate
DB_SSL_MODE=disable

# ===== JWT Settings =====
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRATION_SECONDS=604800

# ===== SMTP Settings =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_SENDER_ADDRESS=
SMTP_SENDER_NAME=SaaS Application

# ===== Admin Seed =====
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ===== Misc =====
PHONE_COUNTRY_CODE_DEFAULT=62
BODY_LIMIT=100M
DEBUG=false
RECORDINGS_ROOT=/app/recordings
FFMPEG_BIN=ffmpeg
GO2RTC_API_URL=http://go2rtc:1984
GO2RTC_RTSP_URL=rtsp://go2rtc:8554
GO2RTC_STREAM_PREFIX=camera_
NVR_SEGMENT_SECONDS=3600
NVR_RETENTION_INTERVAL_SECONDS=300
NVR_HEALTH_STALE_SECONDS=600
NVR_SNAPSHOT_CACHE_SECONDS=60
NVR_SNAPSHOT_TIMEOUT_SECONDS=10
NVR_WORKER_INITIAL_BACKOFF_SECONDS=2
NVR_WORKER_MAX_BACKOFF_SECONDS=60
NVR_WORKER_STOP_TIMEOUT_SECONDS=10

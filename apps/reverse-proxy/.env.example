# Reverse Proxy Settings

# Port for the reverse proxy to listen on
PORT=7777

# Backend API URL
BACKEND_URL=http://localhost:3001

# Frontend URL (development mode — proxies to Vite dev server)
FRONTEND_URL=http://localhost:3002

# Static directory (production mode — serves pre-built files)
# When set, FRONTEND_URL is ignored and files are served from this directory
# STATIC_DIR=/app/static

# Public API URL (injected into index.html as window.__RUNTIME_CONFIG__.API_URL)
# Leave empty for relative URLs (same-origin)
# PUBLIC_API_URL=https://api.example.com

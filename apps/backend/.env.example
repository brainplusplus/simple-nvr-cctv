# Application Settings
APP_NAME=Simple-NVR-CCTV
PORT=3001
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_SECONDS=604800
BODY_LIMIT=100M

# Database Settings
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SCHEMA=boilerplate
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300
DB_CONN_MAX_IDLE_TIME=60
DEBUG=false

# SMTP Settings (for email: OTP and forgot password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_SENDER_ADDRESS=
SMTP_SENDER_NAME=SaaS Application

# Default admin credentials (used for initial seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Phone country code default (for phone number normalization)
PHONE_COUNTRY_CODE_DEFAULT=62
RECORDINGS_ROOT=recordings
FFMPEG_BIN=ffmpeg
GO2RTC_API_URL=http://127.0.0.1:1984
GO2RTC_RTSP_URL=rtsp://127.0.0.1:8554
GO2RTC_STREAM_PREFIX=camera_
NVR_SEGMENT_SECONDS=3600
NVR_RETENTION_INTERVAL_SECONDS=300
NVR_HEALTH_STALE_SECONDS=600
NVR_SNAPSHOT_CACHE_SECONDS=60
NVR_SNAPSHOT_TIMEOUT_SECONDS=10
NVR_WORKER_INITIAL_BACKOFF_SECONDS=2
NVR_WORKER_MAX_BACKOFF_SECONDS=60
NVR_WORKER_STOP_TIMEOUT_SECONDS=10

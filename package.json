{
    "name": "simple-nvr-cctv-root",
    "private": true,
    "scripts": {
        "dev:frontend": "cd apps/frontend && bun run dev",
        "dev:backend": "cd apps/backend && go run main.go",
        "dev:proxy": "cd apps/reverse-proxy && go run main.go",
        "dev:relay": "node scripts/dev-relay.js",
        "dev": "concurrently --kill-others \"bun run dev:relay\" \"bun run dev:backend\" \"bun run dev:frontend\" \"bun run dev:proxy\"",
        "build:frontend": "cd apps/frontend && bun run build",
        "build:backend": "cd apps/backend && go build -o ../bin/backend.exe .",
        "build:proxy": "cd apps/reverse-proxy && go build -o ../bin/reverse-proxy.exe .",
        "build": "bun run build:frontend && bun run build:backend && bun run build:proxy",
        "prod:backend": "cd apps/bin && backend.exe",
        "prod:proxy": "cd apps/bin && reverse-proxy.exe",
        "prod": "concurrently --kill-others \"bun run prod:backend\" \"bun run prod:proxy\"",
        "kill:bat": "kill_port.bat",
        "kill:ps1": "kill_port.ps1",
        "generate": "bun scripts/generate.js"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    },
    "dependencies": {
        "chalk": "^4.1.2",
        "figlet": "^1.10.0",
        "inquirer": "^8.0.0",
        "ora": "^5.4.1"
    }
}
